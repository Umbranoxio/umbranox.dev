---
import Navbar from '../components/navbar.astro';
import Head from '../components/head.astro';

interface Props {
   title: string;
   description: string;
   image?: string;
   imageHeight?: string;
   imageWidth?: string;
   bodyClass?: string;
   mainClass?: string;
}

const { title, description, image, imageHeight, imageWidth, bodyClass, mainClass } = Astro.props;
---

<html lang="en">
   <head>
      <Head title={title} description={description} image={image} imageHeight={imageHeight} imageWidth={imageWidth} />
   </head>
   <body class:list={['main bg-page text-body', bodyClass]}>
      <a class="skip-link" href="#main">skip to content</a>
      <Navbar />
      <main id="main" tabindex="-1" class={mainClass}>
         <slot />
      </main>
   </body>
</html>
