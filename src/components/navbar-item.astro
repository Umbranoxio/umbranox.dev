---
interface Props {
   href: string;
   title: string;
}

const { href, title } = Astro.props;

const { pathname } = Astro.url;
const currentPath = pathname.replace(/\/$/, '') || '/';
const itemPath = href.replace(/\/$/, '') || '/';
const active = itemPath === '/' ? currentPath === '/' : currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
---

<a
   href={href}
   data-astro-prefetch
   aria-current={active ? 'page' : undefined}
   class={`${active ? 'bg-surface-active text-strong' : 'bg-transparent hover:text-nav-hover'} m-1 inline-flex h-7 w-12 shrink-0 items-center justify-center rounded-sm leading-none transition-none`}
>
   {title}
</a>
