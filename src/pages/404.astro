---
import MainLayout from '../layouts/main.astro';
---

<MainLayout
   title="404 | umbranox"
   description="page not found"
   image="/android-chrome-192x192.png"
   imageHeight="192"
   imageWidth="192"
   mainClass="absolute inset-0 flex items-center justify-center px-4 py-8"
>
   <div class="flex flex-col items-center justify-center space-y-4 text-center">
      <div class="size-20 logo">
         <img class="size-full" src="/logo.svg" alt="" decoding="async" />
      </div>
      <p class="cursor-default text-2xl font-bold tracking-brand transition-colors duration-500 hover:text-nav-hover">404</p>
      <h1 class="cursor-default text-4xl font-bold leading-tight tracking-brand transition-colors duration-500 hover:text-nav-hover sm:text-5xl">
         someones lost
      </h1>
   </div>
</MainLayout>
