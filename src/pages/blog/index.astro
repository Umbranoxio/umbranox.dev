---
import MainLayout from '../../layouts/main.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format-date';

const posts = (await getCollection('blog')).sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());
---

<MainLayout title="blog | umbranox" description="the place where i write things" bodyClass="blog-listing">
   <div class="mx-auto mt-10 max-w-2xl px-4">
      <h1 class="mt-8 flex items-center justify-center text-center text-xl font-semibold">
         <span class="size-14 logo" transition:name="site-logo">
            <img class="size-full" src="/logo.svg" alt="" decoding="async" />
         </span>
         <span class="ml-2">
            umbra's blog
         </span>
      </h1>

      <ul class="mt-8 mb-8">
         {
            posts.map((post, index) => (
               <li class="mt-2">
                  <a class="block rounded-lg" href={`/blog/${post.id}`} data-astro-prefetch>
                     <article class="flex flex-col rounded-lg border border-line bg-surface/85 p-2 transition-colors hover:border-nav-hover/40 hover:bg-surface/65 md:flex-row">
                        <img
                           class="h-auto rounded-lg max-md:w-full md:self-center"
                           width="160"
                           height="60"
                           src={post.data.image}
                           alt=""
                           loading={index === 0 ? 'eager' : 'lazy'}
                           decoding="async"
                           fetchpriority={index === 0 ? 'high' : undefined}
                           transition:name={`blog-image-${post.id}`}
                        />
                        <div class="mt-2 flex flex-col md:mt-0 md:ml-4 md:justify-center">
                           <h2 class="text-xl font-semibold text-ellipsis" transition:name={`blog-title-${post.id}`}>
                              {post.data.title}
                           </h2>
                           <div class="flex flex-wrap gap-x-1 text-sm text-muted" transition:name={`blog-date-${post.id}`}>
                              <p>posted on <time datetime={post.data.publishDate}>{formatDate(post.data.publishDate)}</time></p>
                              {post.data.publishDate !== post.data.updatedDate && (
                                 <p>- updated <time datetime={post.data.updatedDate}>{formatDate(post.data.updatedDate)}</time></p>
                              )}
                           </div>
                        </div>
                     </article>
                  </a>
               </li>
            ))
         }
      </ul>
   </div>
</MainLayout>
