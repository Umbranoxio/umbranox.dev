---
import MainLayout from '../layouts/main.astro';
import Socials from '../components/socials.astro';
---

<MainLayout
   title="home | umbranox"
   description="some software dev"
   image="/android-chrome-192x192.png"
   imageHeight="192"
   imageWidth="192"
   bodyClass="home overflow-hidden"
   mainClass="absolute inset-0 flex items-center justify-center px-4 py-8"
>
   <div class="flex flex-col items-center justify-center space-y-4 text-center">
      <div class="relative -top-2 size-20 logo" transition:name="site-logo">
         <img class="size-full" src="/logo.svg" alt="" decoding="async" />
      </div>
      <h1 class="cursor-default text-4xl font-bold tracking-brand transition-colors duration-500 hover:text-nav-hover sm:text-5xl">umbranox</h1>
      <Socials />
   </div>
</MainLayout>
